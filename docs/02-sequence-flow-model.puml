@startuml Sequence Model - Operation Flow

!theme plain
skinparam sequenceArrowThickness 2
skinparam roundcorner 20
skinparam maxmessagesize 60
skinparam sequenceParticipant underline

actor "Vehicle A" as VehicleA
actor "Vehicle B" as VehicleB
participant "Gateway RSU" as RSU
participant "Identity\nService" as Identity
participant "Validator Nodes" as Validators
participant "Leader Node/\nMiner" as Leader
database "Blockchain/DAG" as Ledger

== Alert Generation and Transmission ==
VehicleA -> VehicleA : Detects hazard
VehicleA -> VehicleA : Generates Alert Message
VehicleA -> VehicleA : Signs with Private Key

VehicleA -> VehicleB : Transmits signed\nmessage (V2V)
VehicleA -> RSU : Transmits signed\nmessage (V2I)

== Validation and Aggregation ==
RSU -> Identity : Query Public Key\nof Vehicle A
Identity --> RSU : Returns Public Key

note right
    Validates authenticity
    and integrity
end note
RSU -> RSU : Verifies digital\nsignature

RSU -> Validators : Propagates\nAggregated Transaction

== Consensus ==
Validators -> Validators : Executes Consensus\nAlgorithm (PBFT)
note right
    PBFT Stages:
    1. Request
    2. Pre-prepare
    3. Prepare
    4. Commit
end note

Validators -> Leader : Consensus reached

== Block Creation and Propagation ==
Leader -> Leader : Assembles new block
Leader -> Ledger : Records validated block
Leader -> Validators : Transmits block to network

Validators -> Ledger : Updates local ledger

== Verification by Receiver ==
VehicleB -> Ledger : Queries provenance\nand integrity of alert
Ledger --> VehicleB : Transaction confirmation

note over VehicleA, Ledger
    **Transaction completed successfully**
    Verifiable and immutable alert recorded
end note

@enduml
