{
  "name": "@v2v-blockchain/iota-client",
  "version": "1.0.0",
  "description": "IOTA Tangle (DAG) implementation for V2X ITS security system",
  "main": "client/index.js",
  "type": "module",
  "scripts": {
    "start": "node client/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint ."
  },
  "keywords": [
    "iota",
    "tangle",
    "dag",
    "blockchain",
    "v2x",
    "its",
    "v2v",
    "v2i",
    "vehicular-networks"
  ],
  "author": "Paulo Henrique Gomes Pinto",
  "license": "GPL-2.0",
  "dependencies": {
    "@iota/sdk": "^1.1.0",
    "@iota/identity-wasm": "^1.0.0",
    "dotenv": "^16.3.1",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/sdk-trace-node": "^1.19.0",
    "@opentelemetry/sdk-metrics": "^1.19.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.45.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.45.1",
    "@opentelemetry/exporter-prometheus": "^0.45.1",
    "@opentelemetry/instrumentation": "^0.45.1",
    "@opentelemetry/instrumentation-http": "^0.45.1",
    "@opentelemetry/resources": "^1.19.0",
    "@opentelemetry/semantic-conventions": "^1.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.57.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "extensionsToTreatAsEsm": [".js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "client/**/*.js",
      "!node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
